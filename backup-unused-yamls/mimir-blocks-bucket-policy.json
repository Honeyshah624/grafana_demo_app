{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowMimirListBucket",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "arn:aws:iam::454143665149:role/AmazonEKSAutoNodeRole",
          "arn:aws:iam::454143665149:role/MimirS3PodRole"
        ]
      },
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::retail-mimir-blocks-454143665149"
    },
    {
      "Sid": "AllowMimirObjects",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "arn:aws:iam::454143665149:role/AmazonEKSAutoNodeRole",
          "arn:aws:iam::454143665149:role/MimirS3PodRole"
        ]
      },
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::retail-mimir-blocks-454143665149/*"
    }
  ]
}
